# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your_project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Admin password (protects /admin)
ADMIN_PASSWORD=choose_a_strong_password_here

# PWA Tracker PIN (protects /pwa GPS tracker)
NEXT_PUBLIC_PWA_PIN=1234

# Site URL (for sitemap + OG tags)
NEXT_PUBLIC_SITE_URL=https://road-to-edi.vercel.app

# Resend (email notifications)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Road to Edi <noreply@yourdomain.com>
